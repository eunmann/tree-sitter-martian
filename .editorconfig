root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{c,h}]
indent_size = 4

# Martian sources and tree-sitter corpus fixtures use 4-space indentation.
[*.mro]
indent_size = 4

[Makefile]
indent_style = tab
